{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "ActionType": {
            "enum": [
                "approvalactioned",
                "approvalrequest",
                "assistantmessage",
                "completellmmessage",
                "completemessage",
                "createbot",
                "executionstarted",
                "getbots",
                "getmessages",
                "llminstantiate",
                "notification",
                "updatebot"
            ],
            "type": "string"
        },
        "Approval": {
            "properties": {
                "input": {},
                "toolName": {
                    "type": "string"
                }
            },
            "required": [
                "input",
                "toolName"
            ],
            "type": "object"
        },
        "ApprovalActioned": {
            "properties": {
                "approved": {
                    "type": "boolean"
                },
                "id": {
                    "type": "string"
                }
            },
            "required": [
                "approved",
                "id"
            ],
            "type": "object"
        },
        "ApprovalInput": {
            "properties": {
                "approved": {
                    "type": "boolean"
                },
                "id": {
                    "type": "string"
                },
                "toolName": {
                    "type": "string"
                }
            },
            "required": [
                "approved",
                "id",
                "toolName"
            ],
            "type": "object"
        },
        "ApprovalRequestedFromServer": {
            "allOf": [
                {
                    "properties": {
                        "input": {},
                        "toolName": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "input",
                        "toolName"
                    ],
                    "type": "object"
                },
                {
                    "properties": {
                        "id": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "id"
                    ],
                    "type": "object"
                }
            ]
        },
        "AssistantType": {
            "type": "string"
        },
        "BotIdInput": {
            "properties": {
                "id": {
                    "type": "string"
                }
            },
            "required": [
                "id"
            ],
            "type": "object"
        },
        "BotOutput": {
            "properties": {
                "cron": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "instructions": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            },
            "required": [
                "description",
                "id",
                "instructions",
                "name"
            ],
            "type": "object"
        },
        "ConverseInput": {
            "properties": {
                "id": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                }
            },
            "required": [
                "id",
                "message"
            ],
            "type": "object"
        },
        "CreateBotInput": {
            "properties": {
                "cron": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "instructions": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            },
            "required": [
                "description",
                "instructions",
                "name"
            ],
            "type": "object"
        },
        "ExecuteLLMInput": {
            "properties": {
                "mcpConfigs": {
                    "items": {
                        "$ref": "#/definitions/McpConfig"
                    },
                    "type": "array"
                }
            },
            "required": [
                "mcpConfigs"
            ],
            "type": "object"
        },
        "McpConfig": {
            "anyOf": [
                {
                    "properties": {
                        "args": {
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        "command": {
                            "type": "string"
                        },
                        "env": {
                            "$ref": "#/definitions/Record%3Cstring%2Cstring%3E"
                        }
                    },
                    "required": [
                        "args",
                        "command"
                    ],
                    "type": "object"
                },
                {
                    "properties": {
                        "headers": {
                            "$ref": "#/definitions/Record%3Cstring%2Cstring%3E"
                        },
                        "type": {
                            "$ref": "#/definitions/McpTransportType"
                        },
                        "url": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "type",
                        "url"
                    ],
                    "type": "object"
                }
            ]
        },
        "McpTransportType": {
            "enum": [
                "http",
                "sse"
            ],
            "type": "string"
        },
        "MessageOutput": {
            "properties": {
                "id": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                },
                "reasoning": {
                    "type": "string"
                },
                "timestamp": {
                    "type": "string"
                }
            },
            "required": [
                "id",
                "message",
                "reasoning",
                "timestamp"
            ],
            "type": "object"
        },
        "Record<string,string>": {
            "type": "object"
        },
        "WebSocketInput": {
            "properties": {
                "input": {
                    "anyOf": [
                        {
                            "properties": {
                                "cron": {
                                    "type": "string"
                                },
                                "description": {
                                    "type": "string"
                                },
                                "id": {
                                    "type": "string"
                                },
                                "instructions": {
                                    "type": "string"
                                },
                                "name": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "description",
                                "instructions",
                                "name"
                            ],
                            "type": "object"
                        },
                        {
                            "properties": {
                                "id": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "id"
                            ],
                            "type": "object"
                        },
                        {
                            "properties": {
                                "approved": {
                                    "type": "boolean"
                                },
                                "id": {
                                    "type": "string"
                                },
                                "toolName": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "approved",
                                "id",
                                "toolName"
                            ],
                            "type": "object"
                        },
                        {
                            "properties": {
                                "mcpConfigs": {
                                    "items": {
                                        "$ref": "#/definitions/McpConfig"
                                    },
                                    "type": "array"
                                }
                            },
                            "required": [
                                "mcpConfigs"
                            ],
                            "type": "object"
                        },
                        {
                            "properties": {
                                "id": {
                                    "type": "string"
                                },
                                "message": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "id",
                                "message"
                            ],
                            "type": "object"
                        }
                    ]
                },
                "path": {
                    "type": "string"
                }
            },
            "required": [
                "input",
                "path"
            ],
            "type": "object"
        }
    }
}

